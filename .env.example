# ============================================
# DATABASE
# ============================================
DATABASE_URL=mongodb://localhost:27017/jobflow

# ============================================
# AUTHENTICATION
# ============================================
# Generate using: openssl rand -base64 33
AUTH_SECRET=your_generated_secret_here
NEXTAUTH_SECRET=your_generated_secret_here
NEXTAUTH_URL=http://localhost:3000

# For production deployments
# AUTH_TRUST_HOST=https://yourdomain.com

# ============================================
# OPENAI API (Required for AI Features)
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: Specify model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ============================================
# RAZORPAY (Required for Payments)
# ============================================
# Get your keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# SMTP Settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@jobflow.app
EMAIL_FROM_NAME=JobFlow

# Alternative SMTP variable names (legacy support)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@jobflow.com
# FROM_EMAIL=noreply@jobflow.com

# ============================================
# BRANDING & CUSTOMIZATION (Optional)
# ============================================
# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Favicon Customization
# NEXT_PUBLIC_FAVICON_PATH=/path/to/custom/favicon.ico
NEXT_PUBLIC_FAVICON_LETTER=J
NEXT_PUBLIC_FAVICON_FONT_SIZE=24
NEXT_PUBLIC_FAVICON_BORDER_RADIUS=6
NEXT_PUBLIC_FAVICON_TEXT_COLOR=#FFFFFF
NEXT_PUBLIC_GRADIENT_START=#3B82F6
NEXT_PUBLIC_GRADIENT_END=#1D4ED8

# ============================================
# STATISTICS (Optional - for landing page)
# ============================================
NEXT_PUBLIC_STAT_ACTIVE_USERS=10K+
NEXT_PUBLIC_STAT_JOB_APPLICATIONS=500K+
NEXT_PUBLIC_STAT_RESUMES_ANALYZED=100K+
NEXT_PUBLIC_STAT_SUCCESS_STORIES=5K+

# ============================================
# DEVELOPMENT (Auto-set by framework)
# ============================================
# NODE_ENV=development
